{
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit"
  },
  "files.exclude": {
    "**/bin": true,
    "**/obj": true,
    "**/.git": false
  },
  "dotnet.defaultSolution": "ServiceTemplate.slnx",

  // ── GitHub Copilot ──────────────────────────────────────────────────────────
  "github.copilot.enable": {
    "*": true
  },
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,
  "github.copilot.chat.reviewSelection.enabled": true,
  "github.copilot.chat.generateTests.codeLens": true,
  "github.copilot.chat.fixTestFailure.enabled": true,
  "github.copilot.chat.commitMessageGeneration.instructions": [
    {
      "text": "Use Conventional Commits format: type(scope): description. Types: feat, fix, refactor, test, docs, chore, ci. Keep the subject line under 72 characters."
    }
  ],
  "github.copilot.chat.codeGeneration.instructions": [
    {
      "file": ".github/copilot-instructions.md"
    }
  ]
}
