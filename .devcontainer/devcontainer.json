{
  "name": "ServiceTemplate Dev",
  // Central devcontainer image maintained by the platform team in:
  //   github.com/dever-labs/devcontainers
  // Includes: .NET 10 SDK, Docker-in-Docker, kubectl, Helm, git, GitHub CLI.
  // Update the image there — all service repos pick it up on next container start.
  "image": "ghcr.io/dever-labs/devcontainers/dotnet-service:latest",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csharp",
        "ms-dotnettools.csdevkit",
        "ms-dotnettools.vscode-dotnet-runtime",
        "streetsidesoftware.code-spell-checker",
        "editorconfig.editorconfig",
        "eamodio.gitlens",
        "mhutchie.git-graph",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "redhat.vscode-yaml",
        "humao.rest-client"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.formatOnPaste": true,
        "editor.codeActionsOnSave": {
          "source.organizeImports": "explicit"
        },
        "dotnet.defaultSolution": "ServiceTemplate.sln",
        "omnisharp.enableRoslynAnalyzers": true,
        "omnisharp.enableEditorConfigSupport": true,
        "files.exclude": {
          "**/bin": true,
          "**/obj": true
        }
      }
    }
  },

  // Restores .NET packages, adds Helm repos, updates chart dependencies
  "postCreateCommand": "sh .devcontainer/post-create.sh",
  "postStartCommand": "echo '\\n✅ Dev container ready! Run: make cluster-create && make dev\\n'",

  "remoteUser": "vscode",
  // 8080: app (via skaffold port-forward)
  "forwardPorts": [8080]
}

