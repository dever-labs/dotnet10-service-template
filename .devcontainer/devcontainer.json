{
  "name": "ServiceTemplate Dev",
  // Image-based container — no docker-compose dependency.
  // Backing services (PostgreSQL, OTel Collector) run in the local kind cluster.
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",

  "features": {
    // .NET SDK
    "ghcr.io/devcontainers/features/dotnet:2": {
      "version": "10"
    },
    // Docker-in-Docker — required to run kind cluster nodes inside the container
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest"
    },
    // kubectl + Helm (minikube skipped — we use kind)
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
      "version": "latest",
      "helm": "latest",
      "minikube": "none"
    },
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csharp",
        "ms-dotnettools.csdevkit",
        "ms-dotnettools.vscode-dotnet-runtime",
        "streetsidesoftware.code-spell-checker",
        "editorconfig.editorconfig",
        "eamodio.gitlens",
        "mhutchie.git-graph",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "redhat.vscode-yaml",
        "humao.rest-client"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.formatOnPaste": true,
        "editor.codeActionsOnSave": {
          "source.organizeImports": "explicit"
        },
        "dotnet.defaultSolution": "ServiceTemplate.slnx",
        "omnisharp.enableRoslynAnalyzers": true,
        "omnisharp.enableEditorConfigSupport": true,
        "files.exclude": {
          "**/bin": true,
          "**/obj": true
        }
      }
    }
  },

  // Installs kind, skaffold, restores .NET packages, adds Helm repos
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "echo '\\n✅ Dev container ready! Run: make cluster-create && make dev\\n'",

  "remoteUser": "vscode",
  // 8080: app (via skaffold port-forward)
  "forwardPorts": [8080]
}

