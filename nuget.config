<?xml version="1.0" encoding="utf-8"?>
<!--
  All packages resolve through a single org-level feed that proxies nuget.org
  and hosts internal packages. Switching registries (Azure Artifacts, GitHub
  Packages, Artifactory, Nexus) only requires updating the proxy target —
  this file never changes across the 100s of repos that reference it.

  ┌─────────────────────────────────────────────────────────────────────────┐
  │  TODO: replace the URL below with your organisation's stable feed, e.g. │
  │    https://nuget.internal/v3/index.json  ← vanity domain (best)    │
  │    https://pkgs.dev.azure.com/ORG/_packaging/FEED/nuget/v3/index.json  │
  │    https://nuget.pkg.github.com/ORG/index.json                         │
  └─────────────────────────────────────────────────────────────────────────┘

  nuget.org is kept as a fallback so developers without the internal proxy
  can still build locally. In production CI the proxy aggregates nuget.org
  so no packages are fetched directly from nuget.org there.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="org-nuget-proxy"
         value="https://nuget.internal/v3/index.json"
         protocolVersion="3" />
    <!-- Fallback for local development before the internal proxy is set up -->
    <add key="nuget.org"
         value="https://api.nuget.org/v3/index.json"
         protocolVersion="3" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="org-nuget-proxy">
      <package pattern="*" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
