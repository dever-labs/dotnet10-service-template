{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    },
    "Console": {
      "FormatterName": "json",
      "FormatterOptions": {
        "IncludeScopes": true,
        "TimestampFormat": "yyyy-MM-ddTHH:mm:ss.fffZ "
      }
    }
  },
  "OpenTelemetry": {
    "ServiceName": "service-template",
    "OtlpEndpoint": "http://otel-collector:4317"
  },
  "AuditLog": {
    "UseSyslog": true,
    "SyslogHost": "syslog",
    "SyslogPort": 514,
    "AppName": "service-template"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=servicetemplate;Username=postgres;Password=postgres"
  },
  "AllowedHosts": "*"
}
